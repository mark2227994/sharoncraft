{
  "name": "sharoncraft-website",
  "version": "1.0.0",
  "private": true,
  "description": "Local Node.js workflow for the SharonCraft static storefront.",
  "scripts": {
    "build:release": "npm run build:seo && node scripts/verify-release.js",
    "build:seo": "node scripts/generate-sitemap.js && node scripts/generate-merchant-feed.js",
    "generate:merchant-feed": "node scripts/generate-merchant-feed.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "dev": "node scripts/dev-server.js",
    "dev:open": "node scripts/dev-server.js --open",
    "serve": "node scripts/dev-server.js",
    "serve:5500": "node scripts/dev-server.js --port 5500",
    "predev": "npm run build:seo",
    "predev:open": "npm run build:seo",
    "preserve": "npm run build:seo",
    "preserve:5500": "npm run build:seo"
  },
  "devDependencies": {
    "postcss": "^8.5.8",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
