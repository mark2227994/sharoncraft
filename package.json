{
  "name": "sharoncraft-website",
  "version": "1.0.0",
  "private": true,
  "description": "Next.js redesign for the SharonCraft artisan storefront and admin workspace.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:release": "npm run build:images && npm run build:seo && node scripts/verify-release.js",
    "build:images": "node scripts/generate-responsive-images.js",
    "build:seo": "node scripts/generate-product-share-pages.js && node scripts/generate-sitemap.js && node scripts/generate-merchant-feed.js",
    "generate:merchant-feed": "node scripts/generate-merchant-feed.js",
    "generate:product-share-pages": "node scripts/generate-product-share-pages.js",
    "notify:indexnow": "node scripts/notify-indexnow.js",
    "notify:indexnow:changed": "node scripts/notify-indexnow.js --changed",
    "notify:indexnow:dry": "node scripts/notify-indexnow.js --dry-run",
    "notify:indexnow:changed:dry": "node scripts/notify-indexnow.js --changed --dry-run",
    "optimize:webp-assets": "node scripts/optimize-webp-assets.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "legacy:dev": "node scripts/dev-server.js",
    "legacy:dev:open": "node scripts/dev-server.js --open",
    "legacy:serve": "node scripts/dev-server.js",
    "legacy:serve:5500": "node scripts/dev-server.js --port 5500",
    "static:dev": "node scripts/dev-server.js",
    "static:dev:open": "node scripts/dev-server.js --open",
    "static:serve": "node scripts/dev-server.js",
    "static:serve:5500": "node scripts/dev-server.js --port 5500",
    "prestatic:dev": "npm run build:seo",
    "prestatic:dev:open": "npm run build:seo",
    "prestatic:serve": "npm run build:seo",
    "prestatic:serve:5500": "npm run build:seo"
  },
  "devDependencies": {
    "postcss": "^8.5.8",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.99.0",
    "@vercel/blob": "^2.3.3",
    "date-fns": "^4.1.0",
    "formidable": "^3.5.4",
    "masonry-layout": "^4.2.2",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "sharp": "^0.34.5"
  }
}
