# Optional local development settings.
# The current static frontend still reads Supabase values from
# supabase/supabase-config.js, so this file acts as a reference
# until you wire environment loading into a future toolchain.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
DEV_HOST=127.0.0.1
DEV_PORT=5500
